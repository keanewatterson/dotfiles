{{- $pathVars := dict -}}
{{- template "path-list.tmpl" (dict "Root" . "Vars" $pathVars) -}}
{{- $pathList := index $pathVars "pathList" -}}

{{ if not (findExecutable "atuin" $pathList) -}}

zshaddhistory() {
  local cmd="${1%%$'\n'}"

  # block patterns in HISTORY_IGNORE
  [[ "$cmd" == ${~HISTORY_IGNORE} ]] && return 1

  # block very short commands (under 4 chars)
  (( ${#cmd} < 4 )) && return 1

  # block bare git add (no compound — no && or ;)
  # keeps: git add src/ && git commit -m "..."
  # drops: git add ., git add -A, git add file.py
  [[ "$cmd" =~ '^git add' && ! "$cmd" =~ '(&&|;)' ]] && return 1

  # block alias piped to grep/rg: "alias | grep ..."
  [[ "$cmd" =~ '^alias.*\|' ]] && return 1

  return 0
}

{{- end }}
